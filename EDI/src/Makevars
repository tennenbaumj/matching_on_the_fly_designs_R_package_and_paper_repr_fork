
## EDI Makevars
PKG_CPPFLAGS = -I../inst/include
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) -DNDEBUG -DEIGEN_NO_DEBUG -Wno-ignored-attributes
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) -ltbb12 -fstack-protector

# SIMD: enabled by default via -march=native so the compiler uses every
# instruction set the build machine supports (SSE4.2, AVX2, FMA, AVX-512, ...).
# Eigen and auto-vectorized loops both benefit automatically.
# Disable for portable/cross-compiled builds: EDI_PORTABLE=1 R CMD INSTALL EDI
EDI_PORTABLE ?= 0
ifeq ($(EDI_PORTABLE),0)
PKG_CXXFLAGS += -march=native -mtune=native
endif

# Disable vectorization/autovectorization for benchmark comparisons.
# Enable with: EDI_DISABLE_VECTORIZATION=1 R CMD INSTALL EDI
EDI_DISABLE_VECTORIZATION ?= 0
ifeq ($(EDI_DISABLE_VECTORIZATION),1)
PKG_CPPFLAGS += -DEIGEN_DONT_VECTORIZE -DEIGEN_UNALIGNED_VECTORIZE=0
PKG_CXXFLAGS += -fno-tree-vectorize
endif

# Optional O3 optimisation (separate from SIMD above).
# Disable with: EDI_NATIVE_SPEED=0 R CMD INSTALL EDI
EDI_NATIVE_SPEED ?= 1
ifeq ($(EDI_NATIVE_SPEED),1)
# R's package compile rule appends CXXFLAGS after PKG_CXXFLAGS, even for C++20
# files. Put -O3 there so it wins over site defaults such as CXXFLAGS=-g -O2.
override CXXFLAGS += -O3
endif

# LTO is opt-in. GCC/RcppEigen LTO builds have shown severe slowdowns in the
# small model-fit kernels, so keep the default benchmark/release path non-LTO.
# Enable explicitly with: EDI_NATIVE_LTO=1 R CMD INSTALL EDI
# Debug symbols for perf annotate / source-level profiling.
# Enable with: EDI_DEBUG_SYMBOLS=1 R CMD INSTALL EDI
# Keeps -O3 so profiling reflects real performance; adds DWARF info + frame pointers.
EDI_DEBUG_SYMBOLS ?= 0
ifeq ($(EDI_DEBUG_SYMBOLS),1)
override CXXFLAGS += -g1 -fno-omit-frame-pointer
else
override CXXFLAGS += -g0
endif

EDI_NATIVE_LTO ?= 0
ifeq ($(EDI_NATIVE_LTO),1)
PKG_CXXFLAGS += -flto
PKG_LIBS += -flto
else
PKG_CXXFLAGS += -fno-lto
endif
